# ── trading-bot .env template ─────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git — it contains secrets.
#
# This bot trades QQQ only (→ TQQQ bull / SQQQ bear).
# Uses a single Alpaca CASH account. No swing mode.

# ── Alpaca ────────────────────────────────────────────────────────────────────
# Get your keys from https://alpaca.markets → Paper Trading or Live Trading
# Use a CASH account (not margin) to avoid PDT restrictions at $2k.

ALPACA_API_KEY=your_alpaca_api_key
ALPACA_API_SECRET=your_alpaca_api_secret
ALPACA_IS_PAPER=true            # true = paper trading  |  false = live (⚠️ real money)

# ── Notifications (all optional — leave blank to disable) ─────────────────────

# Email (Gmail recommended — use an App Password, not your login password)
# To create a Gmail App Password:
#   1. myaccount.google.com/security → 2-Step Verification → App passwords
#   2. Create for "Mail" on "Windows Computer"
#   3. Paste the 16-character password below
EMAIL_SENDER=your.gmail@gmail.com
EMAIL_PASSWORD=your_16_char_app_password
EMAIL_RECIPIENT=you@example.com

# Discord webhook
# Create at: Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url

# Telegram bot
# 1. Message @BotFather → /newbot → copy the token
# 2. Message your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
# 3. Find "chat": {"id": 123456789} — that's your chat ID
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=987654321

# ── Sentiment (optional — future integration) ─────────────────────────────────
# Uncomment if you have a sentiment API running
# SENTIMENT_API_URL=http://localhost:8000
# SENTIMENT_ADMIN_TOKEN=your_token

# ── Backtest mode ─────────────────────────────────────────────────────────────
# Set to true when running run_backtest_combined.py to skip Ollama AI grading
# for speed. Automatically set by run_backtest_combined.py — no need to change.
# LUMIBOT_BACKTEST_MODE=false
