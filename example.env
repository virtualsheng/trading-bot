# Alpaca
ALPACA_API_KEY=YOUR_KEY
ALPACA_API_SECRET=YOUR_SECRET
ALPACA_IS_PAPER=true

# Polygon (for backtesting only)
POLYGON_API_KEY=YOUR_POLYGON_KEY

# Sentiment-Trading-Alpha bot
# SENTIMENT_API_URL defaults to http://localhost:8000 if not set
SENTIMENT_API_URL=http://localhost:8000
SENTIMENT_ADMIN_TOKEN=YOUR_SENTIMENT_ADMIN_TOKEN

# Email
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
EMAIL_SENDER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
EMAIL_RECIPIENT=recipient@gmail.com

# Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Telegram
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_CHAT_ID